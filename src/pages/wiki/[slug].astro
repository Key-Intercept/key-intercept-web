---
import Layout from "../../layouts/mainPage.astro";

export async function getStaticPaths() {
    const wikiPages = await import.meta.glob("../../data/wiki/*.md");
    return Object.entries(wikiPages)
        .filter(([path]) => {
            const fileName = path.split("/").pop();
            return !fileName!.startsWith("_");
        })
        .map(([path, page]) => {
            const fileName = path.split("/").pop()!;
            const slug = fileName.replace(".md", "");
            return { params: { slug }, props: { page, allPages: wikiPages } };
        });
}

const { page, allPages } = Astro.props;
const pageModule = (await page()) as {
    Content: any;
    getHeadings?:
        | (() => Array<{ depth: number; slug: string; text: string }>)
        | (() => Promise<Array<{ depth: number; slug: string; text: string }>>);
    headings?: Array<{ depth: number; slug: string; text: string }>;
};
const { Content } = pageModule;

const headingCandidates = pageModule.getHeadings
    ? await pageModule.getHeadings()
    : (pageModule.headings ?? []);

const pageHeadings = headingCandidates.filter(
    (heading) => heading.depth >= 1 && heading.depth <= 3,
);

const navLinks = Object.keys(allPages)
    .filter((path) => {
        const fileName = path.split("/").pop()!;
        return !fileName.startsWith("_") && fileName.endsWith(".md");
    })
    .map((path) => {
        const fileName = path.split("/").pop()!;
        const slug = fileName.replace(".md", "");
        const title = slug.replace(/-/g, " ");
        return { slug, title };
    });
---

<Layout title="Wiki">
    <div class="wiki-layout">
        <aside class="wiki-sidebar">
            <h3>Wiki Navigation</h3>
            <nav>
                <ul>
                    {
                        navLinks.map((link) => (
                            <li>
                                <a
                                    href={`/wiki/${link.slug}`}
                                    class={
                                        Astro.url.pathname ===
                                        `/wiki/${link.slug}`
                                            ? "active"
                                            : ""
                                    }
                                >
                                    {link.title}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            {
                pageHeadings.length > 0 && (
                    <>
                        <h3 class="section-heading">On This Page</h3>
                        <nav>
                            <ul>
                                {pageHeadings.map((heading) => (
                                    <li
                                        class={`toc-item toc-depth-${heading.depth}`}
                                    >
                                        <a href={`#${heading.slug}`}>
                                            {heading.text}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </nav>
                    </>
                )
            }
        </aside>

        <main class="wiki-content">
            <h1>{Astro.params.slug.replace(/-/g, " ")}</h1>
            <div class="markdown-body">
                <Content />
            </div>
        </main>
    </div>
</Layout>

<script>
    const links = document.querySelectorAll(".markdown-body a");

    links.forEach((link) => {
        const href = link.getAttribute("href");
        if (!href) {
            return;
        }

        if (href.startsWith("#") || /^[a-zA-Z]+:\/\//.test(href)) {
            return;
        }

        const [pathPart, hashPart] = href.split("#");
        if (!pathPart.toLowerCase().endsWith(".md")) {
            return;
        }

        const cleanPath = pathPart
            .replace(/^\.\//, "")
            .replace(/^\.\.\//, "")
            .replace(/\.md$/i, "");

        link.setAttribute(
            "href",
            `/wiki/${cleanPath}${hashPart ? `#${hashPart}` : ""}`,
        );
    });
</script>

<style>
    :global(main) {
        color: #eee;
    }

    .wiki-layout {
        display: flex;
        max-width: 1200px;
        margin: 1.5rem auto 2rem;
        background: #1e1e1e;
        min-height: 75vh;
        border: 2px solid #eee;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    }

    /* --- Sidebar Navigation --- */
    .wiki-sidebar {
        width: 280px;
        flex-shrink: 0;
        padding: 2rem;
        border-right: 1px solid #343434;
        background: #181818;
    }

    .wiki-sidebar h3 {
        margin-top: 0;
        font-size: 1.1rem;
        color: #eee;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-family: "Major Mono Display", monospace;
    }

    .section-heading {
        margin-top: 3rem;
    }

    .wiki-sidebar ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .wiki-sidebar li {
        margin-bottom: 0.5rem;
    }

    .toc-item {
        margin-bottom: 0.2rem;
    }

    .toc-depth-3 {
        margin-left: 0.8rem;
    }

    .toc-item a {
        font-size: 0.88rem;
        color: #c7c7c7;
        padding-top: 0.25rem;
        padding-bottom: 0.25rem;
    }

    .toc-item a:hover {
        color: #ffffff;
    }

    .wiki-sidebar a {
        text-decoration: none;
        color: #d9d9d9;
        font-size: 0.95rem;
        display: block;
        padding: 0.4rem 0.6rem;
        border-radius: 8px;
        transition:
            background 0.2s,
            color 0.2s;
        font-family: "Major Mono Display", monospace;
    }

    .wiki-sidebar a:hover {
        background: #2a2a2a;
        color: #fff;
    }

    .wiki-sidebar a.active {
        background: #400bba;
        color: #fff;
        font-weight: 600;
    }

    .wiki-sidebar a:focus-visible,
    .markdown-body a:focus-visible {
        outline: 2px solid #a88bff;
        outline-offset: 2px;
    }

    /* --- Content Area --- */
    .wiki-content {
        flex-grow: 1;
        padding: 2rem 3rem;
        min-width: 0; /* Prevents flexbox blowout on large codeblocks */
        background: #1e1e1e;
        color: #eee;
    }

    .wiki-content h1 {
        margin-top: 0;
        border-bottom: 2px solid #343434;
        padding-bottom: 0.5rem;
        font-family: "Jersey 10", sans-serif;
        font-size: 3rem;
        letter-spacing: 0.02em;
        color: #fff;
    }

    .markdown-body {
        color: #e5e5e5;
        line-height: 1.6;
    }

    .markdown-body h1,
    .markdown-body h2,
    .markdown-body h3,
    .markdown-body h4,
    .markdown-body h5,
    .markdown-body h6 {
        color: #fff;
    }

    /* Basic Markdown Formatting Tweaks */
    .markdown-body img {
        max-width: 100%;
        height: auto;
        border-radius: 6px;
    }

    .markdown-body pre {
        background: #111;
        color: #eee;
        padding: 1rem;
        border-radius: 6px;
        overflow-x: auto;
        border: 1px solid #343434;
    }

    .markdown-body code {
        background: #2a2a2a;
        color: #f5f5f5;
        padding: 0.2em 0.4em;
        border-radius: 3px;
        font-size: 0.9em;
    }

    .markdown-body pre code {
        background: transparent;
        padding: 0;
    }

    :global(.markdown-body a) {
        display: inline-block;
        margin: 0 0.18rem;
        padding: 0.08rem 0.55rem;
        border: 1px solid #6f4bdb;
        border-radius: 999px;
        background: #2a1d57;
        color: #f1ebff;
        text-decoration: none;
        line-height: 1.35;
        transition:
            background 0.2s ease,
            border-color 0.2s ease,
            color 0.2s ease,
            transform 0.1s ease;
    }

    :global(.markdown-body a:visited) {
        color: #efe7ff;
    }

    :global(.markdown-body a:hover) {
        background: #3a2780;
        border-color: #a88bff;
        color: #ffffff;
    }

    :global(.markdown-body a:active) {
        transform: translateY(1px);
    }

    .markdown-body blockquote {
        margin: 1rem 0;
        padding: 0.6rem 1rem;
        border-left: 3px solid #400bba;
        background: #161616;
        color: #d9d9d9;
    }

    @media (max-width: 900px) {
        .wiki-layout {
            flex-direction: column;
            margin: 1rem;
            min-height: auto;
        }

        .wiki-sidebar {
            width: auto;
            border-right: none;
            border-bottom: 1px solid #343434;
        }

        .wiki-content {
            padding: 1.5rem;
        }
    }
</style>
