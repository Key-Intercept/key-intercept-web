---
import Separator from "./separator";


---

<Separator color="white" />
<footer>
    <p>
        Made by <a href="https://discord.com" target="_blank">supersliser</a> on Discord.
    </p>
    <p>
        View the full repository on <a
            href="https://github.com/Key-Intercept/key-intercept"
            target="_blank">GitHub</a
        >.
    </p>
    <p>Things I use in this project:</p>
    <ul>
        <li><a href="https://astro.build">Astro (for the site)</a></li>
        <li><a href="https://vencord.dev/">Vencord (for the PC app)</a></li>
        <li><a href="https://aliucord.com/">Aliucord (for the mobile app)</a></li>
        <li><a href="https://netcord.dev/">Netcord (for the bot)</a></li>
        <li><a href="https://supabase.com/">Supabase (for the backend database)</a></li>
    </ul>
</footer>

<style>
    footer {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: var(--padding-section);
        color: #eee;
        width: 100%;
        gap: var(--spacing-sm);
    }

    footer p {
        margin: var(--spacing-xs) 0;
        font-size: var(--font-size-base);
        text-align: center;
    }

    footer a {
        color: #eee;
        text-decoration: none;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    footer a:hover {
        text-decoration: underline;
        color: var(--color-accent);
    }

    footer ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--spacing-xs);
    }

    footer li {
        font-weight: 400;
        font-size: var(--font-size-base);
    }

    /* Mobile responsive */
    @media (max-width: 768px) {
        footer {
            padding: var(--spacing-md);
        }

        footer p {
            font-size: var(--font-size-base);
        }
    }

    @media (max-width: 480px) {
        footer {
            padding: 1rem;
        }

        footer p {
            margin: 0.5rem 0;
            font-size: 0.95rem;
        }

        footer li {
            font-size: 0.95rem;
        }
    }
</style>
