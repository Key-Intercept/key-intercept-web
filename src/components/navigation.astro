---
import Separator from "./separator";

const routes = [
    {
        name: "Rules",
        path: "/main",
    },
    // {
    //     name: "Pet",
    //     path: "/pet",
    // },
    // {
    //     name: "Bimbo",
    //     path: "/bimbo",
    // },
    // {
    //     name: "Drone",
    //     path: "/drone",
    // },
    {
        name: "Whitelist",
        path: "/whitelist"
    },
    {
        name: "Wiki",
        path: "/wiki/Home",
    },
];

const { title } = Astro.props;
const searchParams = Astro.url.search;
console.log("Current search params:", searchParams);
---

<nav class="nav-container">
    <ul class="nav-list">
        {
            routes.map((route) => (
                <li class="nav-item">
                    <a class="nav-link" href={route.path + searchParams}>
                        {route.name}
                        <Separator color={title === route.name ? "#400bba" : "white"} />
                    </a>
                </li>
            ))
        }
    </ul>
</nav>

<style>
    .nav-container {
        padding: var(--spacing-md) var(--spacing-sm);
        width: 100%;
        overflow-x: auto;
    }

    .nav-list {
        list-style: none;
        display: flex;
        text-align: center;
        justify-content: space-around;
        margin: 0;
        padding: 0;
        gap: var(--spacing-sm);
        flex-wrap: wrap;
    }

    .nav-item {
        flex: 1;
        min-width: 100px;
    }

    .nav-link {
        color: #fff;
        text-decoration: none;
        font-family: "Major Mono Display", monospace;
        font-weight: 400;
        font-style: normal;
        display: flex;
        flex-direction: column;
        align-items: stretch;
        width: 100%;
        font-size: var(--font-size-base);
        transition: all 0.3s ease;
        padding: 0.5rem;
        border-radius: 8px;
    }

    .nav-link:hover {
        /* text-decoration: underline; */
        background-color: rgba(64, 11, 186, 0.1);
    }

    /* Tablet */
    @media (max-width: 768px) {
        .nav-container {
            padding: var(--spacing-md) 0.5rem;
        }

        .nav-item {
            min-width: 80px;
        }

        .nav-link {
            font-size: var(--font-size-base);
            padding: 0.4rem;
        }
    }

    /* Mobile */
    @media (max-width: 480px) {
        .nav-container {
            padding: var(--spacing-sm) 0.25rem;
        }

        .nav-list {
            gap: 0.25rem;
        }

        .nav-item {
            flex: 1;
            min-width: 70px;
        }

        .nav-link {
            font-size: 0.85rem;
            padding: 0.35rem 0.25rem;
        }
    }
</style>
