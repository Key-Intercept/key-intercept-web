---
import Separator from "./separator";

const routes = [
    {
        name: "Rules",
        path: "/main",
    },
    // {
    //     name: "Pet",
    //     path: "/pet",
    // },
    // {
    //     name: "Bimbo",
    //     path: "/bimbo",
    // },
    // {
    //     name: "Drone",
    //     path: "/drone",
    // },
    {
        name: "Whitelist",
        path: "/whitelist"
    },
    {
        name: "Wiki",
        path: "/wiki/Home",
    },
];

const { title } = Astro.props;
const searchParams = Astro.url.search;
console.log("Current search params:", searchParams);
---

<nav>
    <ul>
        {
            routes.map((route) => (
                <li>
                    <a class="nav-link" href={route.path + searchParams}>
                        {route.name}
                        <Separator color={title === route.name ? "#400bba" : "white"} />
                    </a>
                </li>
            ))
        }
    </ul>
</nav>

<style>
    nav {
        padding-top: 1rem;
        padding-bottom: 1rem;
    }

    nav ul {
        list-style: none;
        display: flex;
        text-align: center;
        justify-content: space-around;
        margin: 0;
        padding: 0;
    }

    nav ul li a {
        color: #fff;
        text-decoration: none;
        font-family: "Major Mono Display", monospace;
        font-weight: 400;
        font-style: normal;
    }

    .nav-link {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        width: 100%;
    }

    li {
        width: 20vw;
    }
    

    nav ul li a:hover {
        text-decoration: underline;
    }
</style>
