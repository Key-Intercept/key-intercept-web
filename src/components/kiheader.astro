---
import Separator from "./separator";

const { title } = Astro.props;
---

<header class="header-container">
    <h1>Key Intercept</h1>
    <h2>-</h2>
    <h2>{title}</h2>
</header>
<Separator color="white" />

<style>
    .header-container {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: start;
        padding: 1rem;
        color: #eee;
        width: 100vw;
    }

    .header-container h1 {
        font-size: 2.5rem;
        margin: 0;
        font-family: "Jersey 10", sans-serif;
        font-weight: 400;
        font-style: normal;
    }

    .header-container h2 {
        font-size: 2.5rem;
        margin: 0 0 0 2rem;
        font-family: "Jersey 10", sans-serif;
        font-weight: 400;
        font-style: normal;
    }
</style>
