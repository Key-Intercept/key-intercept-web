---
import Separator from "./separator";

const { title } = Astro.props;
---

<header class="header-container">
    <h1>Key Intercept</h1>
    <span class="separator-inline">-</span>
    <h2>{title}</h2>
</header>
<Separator color="white" />

<style>
    .header-container {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: flex-start;
        flex-wrap: wrap;
        gap: var(--spacing-sm);
        padding: var(--padding-section);
        color: #eee;
        width: 100%;
    }

    .header-container h1 {
        font-size: var(--font-size-xl);
        margin: 0;
        font-family: "Jersey 10", sans-serif;
        font-weight: 400;
        font-style: normal;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .header-container h2 {
        font-size: var(--font-size-xl);
        margin: 0;
        font-family: "Jersey 10", sans-serif;
        font-weight: 400;
        font-style: normal;
        word-break: break-word;
        min-width: 0;
    }

    .separator-inline {
        font-size: var(--font-size-xl);
        flex-shrink: 0;
        color: #eee;
    }

    /* Mobile responsive */
    @media (max-width: 480px) {
        .header-container {
            gap: var(--spacing-xs);
            padding: 0.75rem;
        }

        .header-container h1,
        .header-container h2,
        .separator-inline {
            font-size: var(--font-size-lg);
        }

        .header-container {
            justify-content: center;
            text-align: center;
        }
    }
</style>
